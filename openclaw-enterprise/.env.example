# ==============================================================
# OpenClaw Enterprise — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitear el archivo .env al repositorio.
# ==============================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=openclaw

# URL de conexión completa (usada por el runtime y los scripts)
OPENCLAW_DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}

# ── API Keys de modelos LLM ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

# ── Gateway / Control Plane ────────────────────────────────────
# Generar con: openssl rand -hex 32
OPENCLAW_GATEWAY_PASSWORD=CHANGE_ME_generate_with_openssl

# ── Integraciones opcionales ───────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# GITHUB_TOKEN=
